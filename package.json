{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "桌面番茄钟计时器",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.pomodoro.timer",
    "productName": "番茄钟",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": null,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
